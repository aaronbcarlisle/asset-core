# Copy to sg.env (gitignored) and fill in the script key, then:
#   source sg.env && python scripts/live_shotgrid_mirror.py
# `export` so the values reach the python subprocess when sourced.
export SHOTGRID_URL=https://asset-core-dev.shotgrid.autodesk.com
export SHOTGRID_SCRIPT=assetcore
export SHOTGRID_API_KEY=replace-with-the-script-application-key
