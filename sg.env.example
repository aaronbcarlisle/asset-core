# Copy to sg.env (gitignored) and fill in the script name + key, then run the
# driver (see docs/LIVE_PROVING.md — loading via python is safer than `source` if
# the key contains shell-special characters).
# `export` so the values reach the python subprocess when sourced.
export SHOTGRID_URL=https://asset-core-dev.shotgrid.autodesk.com
export SHOTGRID_SCRIPT=asset-core-dev          # exact script name on the site (case-sensitive)
export SHOTGRID_API_KEY='replace-with-the-script-application-key'   # quote it
export SHOTGRID_PROJECT='Demo: Game'           # id or name; SG Assets are project-scoped
